<Window x:Class="F1RaceEngineer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:widgets="clr-namespace:F1RaceEngineer.Widgets"
        Title="F1 Race Engineer" Height="1000" Width="1500" MinHeight="720" MinWidth="1150"
        Icon="AppIcon.ico"
        Background="#0D1117">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>
        <Style TargetType="Button">
            <!-- Deliberately not green: green is reserved for "personal best / OK" status
                 throughout the app, and reusing it for a plain UI action would dilute that
                 signal. -->
            <Setter Property="Background" Value="#1F6FEB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="BorderBrush" Value="#30363D"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Connection bar + preset tabs, merged into one row (was two stacked rows) -
             three equal-priority zones: connection controls pinned left, tabs truly
             centered on the whole row (not just within leftover space) via matching
             star-widths on the outer columns, settings gear pinned right. -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Every interactive element in this row shares the same explicit Height
                 (24) so nothing looks taller/shorter than its neighbours - the TextBox
                 and Button both carry their own template chrome (focus rings, borders)
                 that would otherwise render taller than the plain Border+TextBlock tabs
                 even with visually-similar Padding values. -->
            <!-- Collapses once the connection is proven (see UpdateConnectionBarVisibility). The
                 permanent home for these controls is the settings panel's CONNECTION section. -->
            <StackPanel x:Name="ConnectionBar" Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="11" Foreground="#6B7684"/>
                <TextBox x:Name="PortTextBox" Width="70" Height="24" Text="20777" FontSize="11"/>
                <Button x:Name="ConnectButton" Content="Connect" Height="24" Margin="10,0,0,0" FontSize="11" Click="ConnectButton_Click"/>
                <TextBlock x:Name="StatusText" Text="Not connected" Margin="14,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#F0883E"/>
            </StackPanel>

            <!-- Preset indicator (auto-driven by SessionType, not clickable) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border x:Name="PracticeTab" Height="24" CornerRadius="4" Padding="12,4" Margin="0,0,6,0">
                    <TextBlock Text="Practice" FontSize="12" VerticalAlignment="Center"/>
                </Border>
                <Border x:Name="QualifyingTab" Height="24" CornerRadius="4" Padding="12,4" Margin="0,0,6,0">
                    <TextBlock Text="Qualifying" FontSize="12" VerticalAlignment="Center"/>
                </Border>
                <Border x:Name="RaceTab" Height="24" CornerRadius="4" Padding="12,4">
                    <TextBlock Text="Race" FontSize="12" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Telemetry setup help. First in the group because it's the one a brand-new user
                     needs before anything else works. Circled question mark, drawn as vectors to
                     match the clock and cog exactly - same 15x15 Viewbox over a 24x24 canvas with
                     Foreground-bound strokes, so all three dim and brighten together. -->
                <ToggleButton x:Name="HelpButton" Style="{StaticResource IconToggleButtonStyle}" ToolTip="How to connect the game"
                              Margin="0,0,6,0" Checked="HelpButton_Checked" Unchecked="HelpButton_Unchecked">
                    <Viewbox Width="15" Height="15">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 3a9 9 0 1 0 0 18 9 9 0 1 0 0-18" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="1.9" StrokeLineJoin="Round"/>
                            <Path Data="M9.2 9.3a2.9 2.9 0 0 1 5.6 1c0 1.9-2.8 2.4-2.8 4.2" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            <Path Data="M12 17.4v.2" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                    </Viewbox>
                </ToggleButton>

                <!-- Race history: opens the saved-race overlay. Clock-with-back-arrow glyph,
                     stroke bound to the button's own Foreground so it dims/brightens with the
                     shared icon-button states. -->
                <ToggleButton x:Name="HistoryButton" Style="{StaticResource IconToggleButtonStyle}" ToolTip="Race history"
                              Margin="0,0,6,0" Checked="HistoryButton_Checked" Unchecked="HistoryButton_Unchecked">
                    <Viewbox Width="15" Height="15">
                        <Canvas Width="24" Height="24">
                            <Path Data="M3 12a9 9 0 1 0 3-6.7L3 8" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            <Path Data="M3 4v4h4" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            <Path Data="M12 8v4l3 2" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas>
                    </Viewbox>
                </ToggleButton>
                <!-- Vector cog (not the ⚙ glyph) so it matches the history icon exactly in
                     size, stroke weight and centring - same 15x15 Viewbox / 24x24 canvas /
                     Foreground-bound stroke, so both dim and brighten together. -->
                <ToggleButton x:Name="SettingsButton"
                              Style="{StaticResource IconToggleButtonStyle}"
                              Checked="SettingsButton_Checked" Unchecked="SettingsButton_Unchecked">
                    <Viewbox Width="15" Height="15">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                            <Path Data="M9 12a3 3 0 1 0 6 0 3 3 0 1 0-6 0"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}" StrokeThickness="1.9" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </Canvas>
                    </Viewbox>
                </ToggleButton>
            </StackPanel>
            <!-- Offset so the panel's right edge meets the gear rather than extending past the
                 window - see the Width note in SettingsPanel.xaml. -->
            <Popup x:Name="SettingsPopup" PlacementTarget="{Binding ElementName=SettingsButton}"
                   Placement="Bottom" HorizontalOffset="-264" StaysOpen="False" Closed="SettingsPopup_Closed">
                <widgets:SettingsPanel x:Name="SettingsFlyoutContent"/>
            </Popup>

            <!-- Telemetry setup card. A Popup, not a Window (no taskbar entry, closes on
                 click-away) and not a full overlay like history - this is reference you want
                 ON TOP of the dashboard while you fix settings, not instead of it. -->
            <!-- HorizontalOffset pulls the card back by its own width so its RIGHT edge lines up
                 with the button rather than its left. Anchored below a button this close to the
                 window edge, the default placement threw most of the card off the right side of
                 the window onto the desktop behind it. The offset is -(Width - button width), so
                 the Border below carries a fixed Width rather than MaxWidth - a content-sized card
                 would make the two disagree and drift. -->
            <Popup x:Name="HelpPopup" PlacementTarget="{Binding ElementName=HelpButton}"
                   Placement="Bottom" HorizontalOffset="-406" StaysOpen="False" Closed="HelpPopup_Closed" AllowsTransparency="True">
                <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="10"
                        Padding="18" Margin="0,6,0,10" Width="430">
                    <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Direction="270" Opacity="0.6"/></Border.Effect>
                    <StackPanel>
                        <TextBlock Text="CONNECTING THE GAME" FontSize="12" FontWeight="Bold" Foreground="#E6EDF3"/>

                        <!-- Live status first: "waiting for data" almost always means the game
                             isn't sending, so naming what the app can see points the user at the
                             right half of the problem before they read a single setting. -->
                        <Border x:Name="HelpStatusBox" CornerRadius="6" Padding="10,7" Margin="0,12,0,0" Background="#11161D">
                            <!-- A Grid, not a horizontal StackPanel: a StackPanel offers its child
                                 infinite width, so TextWrapping never engages and the status line
                                 was silently clipped mid-sentence. -->
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Ellipse x:Name="HelpStatusDot" Grid.Column="0" Width="8" Height="8" VerticalAlignment="Top" Margin="0,4,8,0"/>
                                <TextBlock x:Name="HelpStatusText" Grid.Column="1" FontSize="11.5" Foreground="#E6EDF3" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="In F1 25:  Options → Settings → Telemetry Settings" FontSize="11.5"
                                   Foreground="#9BA7B4" Margin="0,14,0,0" TextWrapping="Wrap"/>

                        <!-- Values, not prose: this is a checklist to hold beside the game's menu.
                             The port echoes the live port box - hardcoding 20777 here would
                             actively mislead anyone who changed it. -->
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="UDP Telemetry" Style="{StaticResource HelpKey}"/>
                                <TextBlock Text="UDP IP Address" Style="{StaticResource HelpKey}"/>
                                <TextBlock Text="UDP Port" Style="{StaticResource HelpKey}"/>
                                <TextBlock Text="UDP Send Rate" Style="{StaticResource HelpKey}"/>
                                <TextBlock Text="UDP Format" Style="{StaticResource HelpKey}"/>
                                <TextBlock Text="UDP Broadcast Mode" Style="{StaticResource HelpKey}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="On" Style="{StaticResource HelpVal}"/>
                                <TextBlock Text="127.0.0.1" Style="{StaticResource HelpVal}"/>
                                <TextBlock x:Name="HelpPortValue" Style="{StaticResource HelpVal}"/>
                                <TextBlock Text="20Hz or 60Hz" Style="{StaticResource HelpVal}"/>
                                <TextBlock Text="2025 or 2026" Style="{StaticResource HelpVal}"/>
                                <TextBlock Text="Off" Style="{StaticResource HelpVal}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Then back out of the menu so the settings save." FontSize="11"
                                   Foreground="#6B7684" Margin="0,10,0,0" TextWrapping="Wrap"/>

                        <!-- Closes the loop: the port above is READ-ONLY here (it's what to type
                             into the game), and the top bar hides its own copy once telemetry is
                             flowing - so without this line a user needing a different port would
                             have nowhere to go. -->
                        <TextBlock FontSize="11" Foreground="#6B7684" Margin="0,6,0,0" TextWrapping="Wrap">
                            <Run Text="Need a different port? Change it in"/>
                            <Hyperlink Click="HelpOpenSettings_Click" Foreground="#58A6FF" TextDecorations="None">Settings → Connection</Hyperlink>
                        </TextBlock>

                        <Border BorderBrush="#232B35" BorderThickness="0,1,0,0" Margin="0,14,0,0" Padding="0,12,0,0">
                            <StackPanel>
                                <TextBlock Text="STILL NO DATA?" FontSize="10" FontWeight="Bold" Foreground="#6B7684"/>
                                <!-- Deliberately no third-party app names: they date badly and
                                     reading like an endorsement isn't this card's job. The
                                     behaviour is what matters, and it's true of any of them. -->
                                <TextBlock Margin="0,7,0,0" FontSize="11" Foreground="#8B97A4" TextWrapping="Wrap"
                                           Text="• Another telemetry app may already hold this port — only one app can use it at a time."/>
                                <TextBlock Margin="0,5,0,0" FontSize="11" Foreground="#8B97A4" TextWrapping="Wrap"
                                           Text="• Allow F1 Race Engineer through Windows Firewall if it prompted on first run."/>
                                <TextBlock Margin="0,5,0,0" FontSize="11" Foreground="#8B97A4" TextWrapping="Wrap"
                                           Text="• You must be in a driving session — menus and replays send nothing."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>

        <!-- Collapsed by default (see MainWindow.xaml.cs SetError) - only reserves space
             when there's actually an error to show, instead of a permanently blank row. -->
        <TextBlock x:Name="ErrorText" Grid.Row="1" Margin="0,0,0,12" Foreground="#F85149" TextWrapping="Wrap" FontSize="11" Visibility="Collapsed"/>

        <!-- Widget area. Deliberately NOT inside a ScrollViewer: a scroll viewport offers its
             child infinite height, which makes star-sizing meaningless - Lap History (below)
             would grow forever and push the catalog widgets off-screen instead of sharing the
             space. The window's MinHeight is what makes dropping the scroll safe: the layout is
             guaranteed a floor to lay out in, so nothing is ever unreachable. -->
        <Grid Grid.Row="2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Auto so this column collapses to zero width (and the tower's own
                         Margin along with it) when the tower is Collapsed outside Race -
                         no code-behind column-width juggling needed. -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT column = the full-field view, identical placement/width on every
                     preset: the Race Position Tower in Race, the position/timing board in
                     Practice & Qualifying. Only one is ever visible at a time, so they share
                     this Auto-width column (which collapses to zero, taking its 12px right
                     margin with it, when neither is shown). 436px on both keeps the left
                     column exactly the same width across all three tabs - the tower drives
                     this number (it needs the room for the grid-delta and tyre-age columns);
                     the Practice/Qual board just gets the matching width for free. -->
                <widgets:RacePositionTowerWidget x:Name="RaceTower" Grid.Column="0" Width="436" Margin="0,0,12,0"/>
                <widgets:PositionListWidget x:Name="PositionList" Grid.Column="0" Width="436" Margin="0,0,12,0"/>

                <!-- The right column's widgets, plus the Alert banner layered on TOP of
                     them (later child = higher Z). The banner floats over the top of this
                     column as a broadcast-style status strip instead of sitting in the flow,
                     so showing/hiding it never pushes the widgets below up or down. It only
                     overlays the top (the current-lap block) - the field view to the
                     left stays fully visible. See AlertBanner.xaml. The single Lap Timing
                     widget is used on every preset now (with history, toggleable) - there's
                     no longer a separate history-less Qualifying instance. -->
                <Grid Grid.Column="1">
                    <!-- Lap Timing takes the slack (star) and the catalog reserves exactly what it
                         needs (auto). The catalog's issue lists are already capped
                         (IssueListMaxEntries), so its worst-case height is bounded and known -
                         which is what lets Lap History absorb the remainder without the widgets
                         below ever shifting as a race fills up. -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <widgets:LapTimingWidget Grid.Row="0" x:Name="LapTiming" Margin="0,0,0,6"/>

                        <!-- Toggleable catalog widgets: arranged into an adaptive grid at runtime
                             (MainWindow.xaml.cs ArrangeWidgets) so remaining widgets grow to fill
                             the space freed by any that are toggled off via the settings panel.
                             No Margin here - ArrangeWidgets assigns it per-widget at runtime based
                             on each widget's actual column position (0 on outer edges, 6 on the
                             inner edges facing a neighbour), since a static value here can't know
                             which widget will end up leftmost/rightmost once toggles change which
                             widgets are visible. -->
                        <Grid Grid.Row="1" x:Name="WidgetGrid">
                            <widgets:TyresWidget x:Name="TyresCtl"/>
                            <widgets:CarConditionWidget x:Name="CarConditionCtl"/>
                            <widgets:PenaltiesFlagsWidget x:Name="PenaltiesFlagsCtl"/>
                            <widgets:SessionTrackWidget x:Name="SessionTrackCtl"/>
                        </Grid>
                    </Grid>
                    <!-- MinHeight tracks the real measured height of Lap Timing's current-lap block
                         (see LapTimingWidget.HeaderExtent), so the strip always covers exactly that
                         block with no hand-measured constant to re-check when fonts change. -->
                    <widgets:AlertBanner x:Name="Alert" VerticalAlignment="Top"
                                         MinHeight="{Binding HeaderExtent, ElementName=LapTiming}"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Cold-start empty state: overlays the whole widget viewport (Grid.Row 2, on top
             of the layout) until the first telemetry packet arrives, so launch doesn't
             show a bare, half-populated layout. A sibling of the widget area rather than a
             child, so it centres in the visible window. Opaque, so it hides whatever's
             behind it. Gated in code
             (UpdateWaitingPlaceholder) on Unsupported preset AND no data yet - so it steps
             aside both for a manual settings-menu preview (which forces a concrete preset)
             and for a live Time Trial (Unsupported but with data flowing). -->
        <Border x:Name="WaitingPlaceholder" Grid.Row="2" Background="#0D1117" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Waiting for a session&#8230;" FontSize="18" FontWeight="SemiBold"
                           Foreground="#8B98A6" HorizontalAlignment="Center"/>
                <TextBlock Text="Start Practice, Qualifying or a Race in F1 25 &#8212; the dashboard fills in automatically."
                           FontSize="12" Foreground="#5A6470" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                <TextBlock Text="Or preview a layout from the &#9881; settings menu."
                           FontSize="11" Foreground="#4A5460" Margin="0,4,0,0" HorizontalAlignment="Center"/>

                <!-- Offers help at the moment it's needed rather than waiting to be found. This is
                     the screen a user stares at when it isn't working, so the prompt belongs here
                     as well as behind the "?" icon - someone who doesn't know the icon exists will
                     never click it. -->
                <TextBlock HorizontalAlignment="Center" Margin="0,16,0,0" FontSize="11.5">
                    <Hyperlink Click="HelpLink_Click" Foreground="#58A6FF" TextDecorations="None"
                               ToolTip="Show the in-game telemetry settings">Not receiving data? Check your in-game telemetry settings</Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Race-history overlay: covers the whole widget viewport (on top of the waiting
             placeholder too) when the history icon is toggled on. Toggled in code-behind,
             which reloads the saved races each time it opens. -->
        <widgets:HistoryPanel x:Name="History" Grid.Row="2" Visibility="Collapsed"/>
    </Grid>
</Window>
