<Application x:Class="F1RaceEngineer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Simple pole + pennant flag icon, shared by the alert banner and the
             Penalties & Flags chip, so flag states read as a shape, not just text. -->
        <Geometry x:Key="FlagPoleGeometry">M3,1 L3,23</Geometry>
        <Geometry x:Key="FlagPennantGeometry">M3,3 L15,7 L3,11 Z</Geometry>

        <!-- Shared "all clear" checkmark - used by Car Condition and Penalties & Flags for
             their quiet OK state, so a healthy status reads as a small confirmation, not a
             loud banner competing with the yellow issue list it sits next to. -->
        <Geometry x:Key="CheckmarkGeometry">M4,13 L9,18 L20,6</Geometry>

        <!-- Every widget card shares this: dark rounded panel, stretched to match the
             tallest card in its adaptive-grid row (standard dashboard-card convention -
             cards in the same row should share a height). Each widget centers its own
             content vertically (see each widget's root panel) so a short widget's content
             sits comfortably in the middle of the taller shared card instead of pinned to
             the top with visible empty space underneath. -->
        <Style x:Key="WidgetCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#11161D"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
        </Style>

        <!-- Common size for a widget's primary stat number, so numbers read at a
             consistent size across Gaps, Tyres, and Fuel & ERS instead of each widget
             having picked its own size independently. -->
        <Style x:Key="HeroNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Foreground" Value="#E6EDF3"/>
        </Style>

        <!-- Flat icon-button look for the settings gear: transparent until hovered/open,
             fully rounded (circular for a square Width=Height), so it reads as a plain
             icon sitting on the toolbar rather than a separate coloured square control. -->
        <Style x:Key="IconToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9BA7B4"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1C2733"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1C2733"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Muted, transparent-until-hovered look for the preset preview buttons - a
             dev convenience, so it shouldn't visually compete with the real controls. -->
        <Style x:Key="PreviewButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9BA7B4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#232B35"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E6EDF3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box" Width="18" Height="18" CornerRadius="4"
                                    Background="#1C2733" BorderBrush="#3A4552" BorderThickness="1"
                                    VerticalAlignment="Center">
                                <Path x:Name="CheckMark" Data="M3,9 L7,13 L15,3" Stroke="#97C459"
                                      StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round" Visibility="Collapsed"/>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#173404"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#97C459"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#6B7684"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
