<UserControl x:Class="F1RaceEngineer.Widgets.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8" Padding="14" MinWidth="220">
        <StackPanel>
            <TextBlock Text="WIDGETS" FontSize="11" Foreground="#6B7684" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Label}" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                  Foreground="#E6EDF3" FontSize="13" Margin="0,5"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border BorderBrush="#232B35" BorderThickness="0,1,0,0" Margin="0,12,0,10"/>

            <TextBlock Text="PREVIEW MODE" FontSize="10" Foreground="#6B7684" Margin="0,0,0,4"/>
            <TextBlock Text="Force a preset to review its layout without a live connection."
                       FontSize="10" Foreground="#4A5460" TextWrapping="Wrap" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PreviewPracticeButton" Content="Practice" Style="{StaticResource PreviewButtonStyle}" Click="PreviewPractice_Click"/>
                <Button x:Name="PreviewQualifyingButton" Content="Qualifying" Style="{StaticResource PreviewButtonStyle}" Click="PreviewQualifying_Click" Margin="4,0,0,0"/>
                <Button x:Name="PreviewRaceButton" Content="Race" Style="{StaticResource PreviewButtonStyle}" Click="PreviewRace_Click" Margin="4,0,0,0"/>
            </StackPanel>

            <!-- Set from the assembly's informational version (App.csproj's <Version>)
                 in code-behind, not bound - this is static build metadata, not live
                 telemetry state. Tucked down here rather than anywhere on the main
                 dashboard so it stays out of the way while racing. -->
            <TextBlock x:Name="VersionText" FontSize="10" Foreground="#4A5460"
                       HorizontalAlignment="Right" Margin="0,10,0,0"/>
        </StackPanel>
    </Border>
</UserControl>
