<UserControl x:Class="F1RaceEngineer.Widgets.LapTimingWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:widgets="clr-namespace:F1RaceEngineer.Widgets"
             mc:Ignorable="d" d:DesignWidth="480">

    <Border Style="{StaticResource WidgetCardStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <!-- Star: Lap History absorbs whatever height is left in the window, so a tall
                     window shows more laps instead of leaving dead space. It never grows with the
                     race itself (the viewport scrolls), so the widgets below still never shift. -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: current lap / personal best / delta. Named so the Alert banner can size
                 itself to exactly cover this block (see HeaderExtent in the code-behind). -->
            <Grid x:Name="HeaderBlock" Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="CURRENT LAP" FontSize="11" Foreground="#6B7684" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CurrentLapTimeText}" FontSize="30" FontWeight="Bold"
                                   Foreground="{Binding CurrentLapColorBrush}" FontFamily="Consolas"/>
                        <Border Background="#791F1F" CornerRadius="4" Padding="6,2" Margin="8,6,0,0" VerticalAlignment="Top"
                                Visibility="{Binding IsCurrentLapInvalid, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="INVALID" FontSize="10" FontWeight="Bold" Foreground="#F09595"/>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="PERSONAL BEST" FontSize="11" Foreground="#6B7684" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding PersonalBestLapText}" FontSize="26" FontWeight="Bold"
                               Foreground="{Binding PersonalBestLapColorBrush}" FontFamily="Consolas"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="DELTA VS PERSONAL BEST" FontSize="11" Foreground="#6B7684" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding DeltaToPbText}" FontSize="26" FontWeight="Bold"
                               Foreground="{Binding DeltaToPbColorBrush}" FontFamily="Consolas"/>
                </StackPanel>
            </Grid>

            <!-- Row 1: sectors, full width, large text -->
            <StackPanel Grid.Row="1" Margin="0,0,0,4">
                <TextBlock Text="SECTORS" FontSize="11" Foreground="#6B7684" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="{Binding Sector1BackgroundBrush}" CornerRadius="6" Padding="0,8">
                        <StackPanel>
                            <TextBlock Text="S1" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{Binding Sector1TextBrush}"/>
                            <TextBlock Text="{Binding Sector1Text}" FontSize="21" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{Binding Sector1TextBrush}" FontFamily="Consolas" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Background="{Binding Sector2BackgroundBrush}" CornerRadius="6" Padding="0,8">
                        <StackPanel>
                            <TextBlock Text="S2" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{Binding Sector2TextBrush}"/>
                            <TextBlock Text="{Binding Sector2Text}" FontSize="21" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{Binding Sector2TextBrush}" FontFamily="Consolas" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="4" Background="{Binding Sector3BackgroundBrush}" CornerRadius="6" Padding="0,8">
                        <StackPanel>
                            <TextBlock Text="S3" FontSize="13" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{Binding Sector3TextBrush}"/>
                            <TextBlock Text="{Binding Sector3Text}" FontSize="21" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{Binding Sector3TextBrush}" FontFamily="Consolas" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Row 2: divider -->
            <Border Grid.Row="2" BorderBrush="#232B35" BorderThickness="0,1,0,0" Margin="0,12,0,10"
                    Visibility="{Binding ShowHistory, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}"/>

            <!-- Row 3: lap history. A Grid (not StackPanel) so the scrolling viewport below can
                 take the row's leftover height rather than sizing to its content. -->
            <Grid Grid.Row="3"
                  Visibility="{Binding ShowHistory, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="LAP HISTORY" FontSize="11" Foreground="#6B7684" Margin="0,0,0,8"/>

                <!-- Right margin (14 = 8px scrollbar gutter + 6px breathing room) matches
                     the row content's total right inset below (6px ScrollViewer padding +
                     8px scrollbar), so the right-aligned DELTA header stays lined up with
                     the row deltas whether or not the scrollbar thumb is showing. -->
                <Grid Grid.Row="1" Margin="0,0,14,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="94"/>
                        <ColumnDefinition Width="94"/>
                        <ColumnDefinition Width="116"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="LAP" FontSize="11" Foreground="#4A5460"/>
                    <TextBlock Grid.Column="1" Text="S1" FontSize="11" Foreground="#4A5460"/>
                    <TextBlock Grid.Column="2" Text="S2" FontSize="11" Foreground="#4A5460"/>
                    <TextBlock Grid.Column="3" Text="S3" FontSize="11" Foreground="#4A5460"/>
                    <TextBlock Grid.Column="5" Text="PIT" FontSize="11" Foreground="#4A5460"/>
                    <TextBlock Grid.Column="7" Text="TIME" FontSize="11" Foreground="#4A5460"/>
                    <TextBlock Grid.Column="8" Text="DELTA" FontSize="11" Foreground="#4A5460" HorizontalAlignment="Right"/>
                </Grid>

                <!-- Elastic viewport: takes this row's leftover height, so a tall window shows more
                     laps rather than dead space, and a short one yields to the catalog widgets
                     below instead of pushing them off-screen. Deliberately NO MinHeight: this sits
                     in a star row, which hands out whatever is left regardless of a child's
                     minimum - so a MinHeight here doesn't reserve anything, it just makes the
                     viewport overflow and clip (verified: it read as a 6-row "floor" while
                     actually rendering nothing at a small window). A real floor would have to go
                     on the RowDefinition, and that space would come straight out of the catalog,
                     pushing widgets off-screen - the exact failure this layout exists to avoid.
                     So the priority when height runs out is: current lap + sectors + widgets stay,
                     history yields. It never sizes to the race's lap count either, so the widgets
                     below never shift as laps accumulate (every lap is kept - see TelemetryState).
                     Padding right 6 holds the row content clear of the scrollbar; combined with the
                     8px scrollbar that's a 14px right inset, matched by the header margin above.
                     Scrollbar visibility is Visible (not Auto) purely to reserve the gutter
                     permanently - the themed ScrollBar in App.xaml hides its own thumb when
                     there's nothing to scroll. -->
                <ScrollViewer Grid.Row="2" Padding="0,0,6,0" VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding LapHistory}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="94"/>
                                        <ColumnDefinition Width="94"/>
                                        <ColumnDefinition Width="116"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding LapNumberText}" FontSize="18" Foreground="#E6EDF3" FontFamily="Consolas" VerticalAlignment="Center"/>

                                    <!-- Margin on the right of each sector block (not just its
                                         underline) is what actually creates breathing room before
                                         the next sector - without it the numbers read as one long
                                         string at a glance, which is the opposite of what this
                                         widget is for. -->
                                    <StackPanel Grid.Column="1" Margin="0,0,24,0">
                                        <TextBlock Text="{Binding Sector1Text}" FontSize="18" FontWeight="Bold" Foreground="{Binding Sector1Brush}" FontFamily="Consolas"/>
                                        <Border Height="2" Background="{Binding Sector1Brush}" Margin="0,4,0,0" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="0,0,24,0">
                                        <TextBlock Text="{Binding Sector2Text}" FontSize="18" FontWeight="Bold" Foreground="{Binding Sector2Brush}" FontFamily="Consolas"/>
                                        <Border Height="2" Background="{Binding Sector2Brush}" Margin="0,4,0,0" HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Margin="0,0,24,0">
                                        <TextBlock Text="{Binding Sector3Text}" FontSize="18" FontWeight="Bold" Foreground="{Binding Sector3Brush}" FontFamily="Consolas"/>
                                        <Border Height="2" Background="{Binding Sector3Brush}" Margin="0,4,0,0" HorizontalAlignment="Stretch"/>
                                    </StackPanel>

                                    <!-- EVENTS gap: SC/VSC, red flag, chequered, and genuine
                                         penalty chips for this lap (empty on a green lap). -->
                                    <ItemsControl Grid.Column="4" ItemsSource="{Binding Events}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="44,0,8,0">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate><DataTemplate><widgets:LapEventChip/></DataTemplate></ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Populated on the two pit-related laps only (blank elsewhere,
                                         like the tag beside it): the OUT row's total pit-lane time
                                         and the IN row's box time - see LapHistoryEntry.PitStopTimeText. -->
                                    <TextBlock Grid.Column="5" Text="{Binding PitStopTimeText}" FontSize="14" FontWeight="Bold" Foreground="#79C0FF" FontFamily="Consolas" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                    <!-- Tag gets its own column rather than sharing one with Time -
                                         a shared column shifted Time right on tagged laps only,
                                         breaking vertical alignment with the untagged laps above/
                                         below it. Its own fixed column keeps Time's start position
                                         identical whether or not a tag is present. -->
                                    <Border Grid.Column="6" Background="#1C2733" CornerRadius="4" Width="38" Padding="0,3" HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Visibility="{Binding HasLapTag, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{Binding LapTagText}" FontSize="13" FontWeight="Bold" Foreground="#9BA7B4" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Grid.Column="7" Text="{Binding LapTimeText}" FontSize="21" FontWeight="Bold" Foreground="{Binding ColorBrush}" FontFamily="Consolas" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="8" Text="{Binding DeltaText}" FontSize="17" Foreground="#6B7684" FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                                <Border BorderBrush="#1C2733" BorderThickness="0,0,0,1" Margin="0,9,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</UserControl>
