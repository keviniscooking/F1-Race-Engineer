<UserControl x:Class="F1RaceEngineer.Widgets.HistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:widgets="clr-namespace:F1RaceEngineer.Widgets"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600">

    <UserControl.Resources>
        <!-- Flat card button: the whole GP card is clickable to open its detail. -->
        <Style x:Key="HistoryCardButton" TargetType="Button">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="BorderBrush" Value="#232B35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover lift: brighter surface/border plus a soft drop shadow so the
                                 focused card reads as raised off the page. -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A212B"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3A4B60"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="3" Direction="270" Opacity="0.55"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon action (export / delete) shown on card hover and in the detail header. -->
        <Style x:Key="MiniAction" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#9BA7B4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="#30363D"
                                BorderThickness="1" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3D4A5C"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background" Value="#1F6FEB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2B7BF5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#0D1117">
        <Grid Margin="16">

            <!-- ============ LIST VIEW ============ -->
            <Grid x:Name="ListRoot">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="2,0,2,14">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                            <TextBlock Text="RACE HISTORY" FontSize="15" FontWeight="Bold" Foreground="#E6EDF3"/>
                            <TextBlock x:Name="CountText" FontSize="12" Foreground="#6B7684" Margin="12,0,0,1" VerticalAlignment="Bottom"/>
                        </StackPanel>
                        <TextBlock Text="Sorted by most recent" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                   FontSize="11" Foreground="#6B7684"/>
                    </Grid>
                    <!-- Save switcher: filter to one career save, or ALL. Built in code from the
                         loaded saves; hidden when there's only one. -->
                    <WrapPanel x:Name="SaveFilterBar" Margin="0,12,0,0" Visibility="Collapsed"/>
                </StackPanel>

                <TextBlock x:Name="EmptyState" Grid.Row="1" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360"
                           Text="No saved races yet. Finish a race with the app connected and it appears here automatically."
                           Foreground="#5A6470" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

                <ScrollViewer x:Name="ListScroller" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0" SizeChanged="ListScroller_SizeChanged">
                    <!-- One section per season (SeasonGroupView): a header with the season's summary
                         stats, then that season's weekend cards. -->
                    <ItemsControl x:Name="SeasonList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,18">
                                    <!-- season header + summary strip -->
                                    <Grid Margin="2,0,2,12">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="Bold" Foreground="#37BEDD"/>
                                            <!-- which career save: livery dot + team · driver -->
                                            <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center"
                                                        Visibility="{Binding HasIdentity, Converter={StaticResource BoolToVis}}">
                                                <Border Width="7" Height="7" CornerRadius="3.5" Background="{Binding IdentityBrush}" VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                <TextBlock Text="{Binding IdentityText}" FontSize="11" Foreground="#8B97A4" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <StackPanel Margin="0,0,20,0">
                                                <TextBlock Text="{Binding RacesText}" FontSize="15" FontWeight="Bold" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                                                <TextBlock Text="RACES" FontSize="8.5" Foreground="#4A5460" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,20,0">
                                                <TextBlock Text="{Binding WinsText}" FontSize="15" FontWeight="Bold" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                                                <TextBlock Text="WINS" FontSize="8.5" Foreground="#4A5460" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,20,0">
                                                <TextBlock Text="{Binding PodiumsText}" FontSize="15" FontWeight="Bold" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                                                <TextBlock Text="PODIUMS" FontSize="8.5" Foreground="#4A5460" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,20,0">
                                                <TextBlock Text="{Binding PointsText}" FontSize="15" FontWeight="Bold" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                                                <TextBlock Text="POINTS" FontSize="8.5" Foreground="#4A5460" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,20,0">
                                                <TextBlock Text="{Binding BestText}" FontSize="15" FontWeight="Bold" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                                                <TextBlock Text="BEST" FontSize="8.5" Foreground="#4A5460" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel Margin="0,0,20,0">
                                                <TextBlock Text="{Binding DnfsText}" FontSize="15" FontWeight="Bold" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                                                <TextBlock Text="DNF" FontSize="8.5" Foreground="#4A5460" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                            <StackPanel>
                                                <TextBlock Text="{Binding AvgText}" FontSize="15" FontWeight="Bold" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
                                                <TextBlock Text="AVG" FontSize="8.5" Foreground="#4A5460" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                    <!-- Season head-to-head: the running scoreboard against the other
                                         human in a two-player career. Absent entirely for a solo
                                         career (HasHeadToHead), so nothing changes for anyone else.
                                         Sits directly under the summary because it answers the same
                                         "how is this season going" question, just against a person
                                         instead of the field. -->
                                    <!-- Visibility and DataContext MUST sit on different elements.
                                         With both on one, the Visibility binding resolves against
                                         the NEW DataContext (the H2H view, which has no
                                         HasHeadToHead), fails silently, and the panel stays
                                         visible - which showed an empty "HEAD TO HEAD" heading on
                                         every solo-career season. -->
                                    <StackPanel Margin="2,10,2,0" Visibility="{Binding HasHeadToHead, Converter={StaticResource BoolToVis}}">
                                      <!-- NOT a card. Boxed, it read as a floating panel dropped into
                                           the header - the only bordered thing between a borderless
                                           season summary above and the bordered race cards below, so
                                           it belonged to neither. Unboxed and set on the same left
                                           margin as the season label, it reads as part of the header
                                           it describes. A single hairline rule carries the grouping
                                           that the border used to.

                                           Row structure mirrors the H2H page's tale of the tape:
                                           each driver's number on their OWN side, metric name centred
                                           between them. Same comparison, same shape, wherever it
                                           appears - and the two sides line up with the header's
                                           "you vs them" above them. -->
                                      <StackPanel DataContext="{Binding HeadToHead}" HorizontalAlignment="Left" Width="270">
                                        <!-- Width is set close to the widest row's natural size on
                                             purpose. Wider, the bars ran on well past the numbers
                                             they describe - long empty tails either side of a
                                             cluster of digits in the middle. Matching the two makes
                                             each bar read as the row's own measure. -->
                                        <Border BorderBrush="#232B35" BorderThickness="0,1,0,0" Margin="0,0,0,10"/>
                                        <Grid Margin="0,0,0,9">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="YOU" FontSize="9.5" FontWeight="Bold" Foreground="#1F6FEB"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="HEAD TO HEAD" FontSize="9" FontWeight="Bold" Foreground="#4A5460"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="14,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding RivalName}" FontSize="9.5" FontWeight="Bold" Foreground="#37BEDD"
                                                       HorizontalAlignment="Left" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding Rows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="0,0,0,9">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding YouText}" FontSize="12.5" FontFamily="Consolas"
                                                                       Foreground="{Binding YouBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="9.5" Foreground="#6B7684"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="14,0"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding RivalText}" FontSize="12.5" FontFamily="Consolas"
                                                                       Foreground="{Binding RivalBrush}" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                                        </Grid>

                                                        <!-- The bar sits UNDER its row rather than between the
                                                             numbers, so the label keeps the centre line. Halves
                                                             are star-sized from the values, so the split IS the
                                                             data and needs no percentage anywhere. -->
                                                        <Border Height="4" CornerRadius="2" Background="#1A222C" ClipToBounds="True" Margin="0,5,0,0">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="{Binding YouWidth}"/>
                                                                    <ColumnDefinition Width="{Binding RivalWidth}"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0" Background="{Binding YouBrush}"/>
                                                                <Border Grid.Column="1" Background="{Binding RivalBrush}"/>
                                                            </Grid>
                                                        </Border>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                      </StackPanel>
                                    </StackPanel>

                                    <Border Height="1" Background="#1B222C" Margin="2,12,2,12"/>

                                    <!-- weekend cards; column count reflows with the panel width -->
                                    <ItemsControl ItemsSource="{Binding Weekends}">
                                        <ItemsControl.ItemsPanel>
                                            <!-- Columns set in code (ApplyCardColumns) - a RelativeSource binding to the
                                                 panel doesn't resolve from inside an ItemsPanelTemplate. -->
                                            <ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button x:Name="CardBtn" Style="{StaticResource HistoryCardButton}" Margin="0,0,12,12" Click="Card_Click" Tag="{Binding}">
                                                    <Grid Margin="15,14">
                                                        <!-- Layered card backdrop: a team-livery wash from the left (identity), the
                                                             result-tinted glow from the top-right (outcome), then the result-tiered
                                                             accent rail down the left edge. -->
                                                        <Border Background="{Binding Race.LiveryHeaderBrush}" CornerRadius="10" Margin="-15,-14"/>
                                                        <Border Background="{Binding Race.ResultGlowBrush}" CornerRadius="10" Margin="-15,-14"/>
                                                        <Border HorizontalAlignment="Left" Width="4" Background="{Binding Race.ResultAccentBrush}" CornerRadius="2"
                                                                Margin="-15,-14,0,-14"/>

                                                        <StackPanel>
                                                            <Grid>
                                                                <StackPanel>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <!-- team livery identity dot -->
                                                                        <Border Width="9" Height="9" CornerRadius="4.5" Background="{Binding Race.TeamLiveryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        <!-- country flag (vector), with the 3-letter code as a fallback -->
                                                                        <Border CornerRadius="2.5" VerticalAlignment="Center" Margin="0,0,8,0" BorderBrush="#3A4552" BorderThickness="1"
                                                                                Visibility="{Binding Race.HasFlag, Converter={StaticResource BoolToVis}}">
                                                                            <Rectangle Width="21" Height="14" RadiusX="1.5" RadiusY="1.5" Fill="{Binding Race.CountryFlagBrush}"/>
                                                                        </Border>
                                                                        <Border Background="#1C2733" CornerRadius="4" Padding="5,1" VerticalAlignment="Center" Margin="0,0,8,0"
                                                                                Visibility="{Binding Race.ShowCountryCode, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="{Binding Race.Country}" FontSize="10" FontFamily="Consolas" FontWeight="Bold" Foreground="#9BA7B4"/>
                                                                        </Border>
                                                                        <TextBlock Text="{Binding Race.GrandPrix}" FontSize="17" FontWeight="Bold" Foreground="#E6EDF3" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                                        <!-- Sprint-weekend badge: this card also holds a Sprint session (open to see it). -->
                                                                        <Border Background="#3A2A12" CornerRadius="4" Padding="5,1" VerticalAlignment="Center" Margin="8,0,0,0"
                                                                                Visibility="{Binding HasSprint, Converter={StaticResource BoolToVis}}">
                                                                            <TextBlock Text="SPRINT" FontSize="9" FontFamily="Consolas" FontWeight="Bold" Foreground="#E0A93B"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Race.CardSubtitle}" FontSize="11" Foreground="#6B7684" Margin="17,3,0,0"/>
                                                                </StackPanel>
                                                                <!-- Result as a medal badge: filled in the tier colour on the podium,
                                                                     an outlined chip for points/finished, red for a DNF; a gold star
                                                                     flags a win. -->
                                                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                                        <TextBlock Text="★" Foreground="#E9C46A" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"
                                                                                   Visibility="{Binding Race.IsWin, Converter={StaticResource BoolToVis}}"/>
                                                                        <Border Background="{Binding Race.FinishBadgeBrush}" BorderBrush="{Binding Race.FinishBadgeBorderBrush}"
                                                                                BorderThickness="1" CornerRadius="8" Padding="11,1,11,3">
                                                                            <TextBlock Text="{Binding Race.FinishText}" Foreground="{Binding Race.FinishBadgeInk}"
                                                                                       FontFamily="Consolas" FontWeight="Bold" FontSize="22"/>
                                                                        </Border>
                                                                    </StackPanel>
                                                                    <TextBlock Text="{Binding Race.DeltaText}" Foreground="{Binding Race.DeltaBrush}" FontFamily="Consolas"
                                                                               FontSize="11" HorizontalAlignment="Right" Margin="0,4,2,0"
                                                                               Visibility="{Binding Race.HasDelta, Converter={StaticResource BoolToVis}}"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- Stat row: every block is label-on-top / value-below for consistency.
                                                                 No fastest-lap badge here - the purple BEST LAP time already signals
                                                                 it (and the detail classification carries the broadcast badge). -->
                                                            <Grid Margin="17,13,0,0" VerticalAlignment="Center">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <!-- The session's fastest lap and who set it, ahead of the
                                                                         player's own best so the two read as "the best" then
                                                                         "mine". Purple is F1's colour for a session fastest lap
                                                                         and is already what the player's own best turns when they
                                                                         hold it, so the pair stays consistent. Hidden entirely
                                                                         when no fastest lap was recorded, rather than showing a
                                                                         dash where a name should be. -->
                                                                    <StackPanel Margin="0,0,26,0"
                                                                                Visibility="{Binding Race.HasSessionFastestLap, Converter={StaticResource BoolToVis}}">
                                                                        <TextBlock Text="FASTEST LAP" FontSize="9.5" Foreground="#4A5460"/>
                                                                        <StackPanel Orientation="Horizontal">
                                                                            <TextBlock Text="{Binding Race.FastestLapText}" FontSize="13" FontFamily="Consolas" Foreground="#AFA9EC"/>
                                                                            <TextBlock Text="{Binding Race.FastestLapBy}" FontSize="9.5" Foreground="#6B7684"
                                                                                       VerticalAlignment="Bottom" Margin="6,0,0,1.5" TextTrimming="CharacterEllipsis" MaxWidth="86"/>
                                                                        </StackPanel>
                                                                    </StackPanel>
                                                                    <StackPanel Margin="0,0,26,0">
                                                                        <TextBlock Text="BEST LAP" FontSize="9.5" Foreground="#4A5460"/>
                                                                        <TextBlock Text="{Binding Race.BestLapText}" FontSize="13" FontFamily="Consolas" Foreground="{Binding Race.BestLapBrush}"/>
                                                                    </StackPanel>
                                                                    <StackPanel>
                                                                        <TextBlock Text="STOPS" FontSize="9.5" Foreground="#4A5460"/>
                                                                        <TextBlock Text="{Binding Race.StopsText}" FontSize="13" FontFamily="Consolas" Foreground="#E6EDF3"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                                <StackPanel HorizontalAlignment="Right">
                                                                    <TextBlock Text="POINTS" FontSize="9.5" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                                                    <TextBlock Text="{Binding WeekendPointsText}" FontSize="13" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Right"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- mini stint bar (built in code-behind from the main race) -->
                                                            <Grid x:Name="CardStint" Height="7" Margin="17,12,0,0" Loaded="CardStint_Loaded" Tag="{Binding}"/>
                                                        </StackPanel>

                                                        <!-- hover actions -->
                                                        <StackPanel x:Name="CardActions" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                                    Margin="0,-4,-4,0" Opacity="0">
                                                            <Button Style="{StaticResource MiniAction}" Click="Export_Click" Tag="{Binding}" ToolTip="Export race as HTML" Margin="0,0,6,0">
                                                                <Path Data="M12,15 V3 M7,8 L12,3 L17,8 M5,15 V19 A2,2 0 0 0 7,21 H17 A2,2 0 0 0 19,19 V15"
                                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8"
                                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="14" Height="14" Stretch="Uniform"/>
                                                            </Button>
                                                            <Button Style="{StaticResource MiniAction}" Click="Delete_Click" Tag="{Binding}" ToolTip="Delete">
                                                                <Path Data="M3,6 H21 M8,6 V4 A1,1 0 0 1 9,3 H15 A1,1 0 0 1 16,4 V6 M18,6 V20 A2,2 0 0 1 16,22 H8 A2,2 0 0 1 6,20 V6"
                                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8"
                                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="14" Height="14" Stretch="Uniform"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Button>
                                                <DataTemplate.Triggers>
                                                    <Trigger SourceName="CardBtn" Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="CardActions" Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ============ DETAIL VIEW ============ -->
            <Grid x:Name="DetailRoot" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Button HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Foreground="#9BA7B4" Click="Back_Click">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="M15,18 L9,12 L15,6" Stroke="#9BA7B4" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="All races" FontSize="12" Foreground="#9BA7B4"/>
                        </StackPanel>
                    </Button>

                    <!-- Race/Sprint switcher, only shown for a Sprint weekend (SessionTabs stays
                         Collapsed otherwise, see OpenDetail). Centered on the row - clear of the
                         left-aligned "All races" button - so the toggle is easy to spot rather than
                         tucked into the far corner. The two sessions share this detail view;
                         clicking a tab repopulates it (see ShowSession). -->
                    <!-- Both toggles sit side by side, centered, and BOTH stay visible at once.
                         That's deliberate: SessionTabs picks WHICH SESSION (Race/Sprint) and
                         ViewTabs picks WHICH VIEW of it (Result/Head to head). Merging the two
                         axes into one strip would force a 2x2 matrix on a sprint weekend; keeping
                         them separate and simultaneously visible is what makes "Sprint" +
                         "HEAD TO HEAD" unambiguous without splitting the weekend card. -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border x:Name="SessionTabs"
                                Background="#11161D" BorderBrush="#232B35" BorderThickness="1" CornerRadius="7" Padding="2" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="RaceTabBtn" CornerRadius="5" Padding="14,5" Background="#1C2733" Cursor="Hand" MouseLeftButtonUp="RaceTab_Click">
                                    <TextBlock Text="RACE" FontSize="11" FontWeight="Bold" Foreground="#E6EDF3"/>
                                </Border>
                                <Border x:Name="SprintTabBtn" CornerRadius="5" Padding="14,5" Background="Transparent" Cursor="Hand" MouseLeftButtonUp="SprintTab_Click" Margin="2,0,0,0">
                                    <TextBlock Text="SPRINT" FontSize="11" FontWeight="Bold" Foreground="#6B7684"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Only shown when the selected session actually has a saved head-to-head
                             (a two-player career with both drivers' laps captured), so a solo
                             career never sees a toggle with nothing behind it. -->
                        <Border x:Name="ViewTabs" Margin="10,0,0,0"
                                Background="#11161D" BorderBrush="#232B35" BorderThickness="1" CornerRadius="7" Padding="2" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="ResultTabBtn" CornerRadius="5" Padding="14,5" Background="#1C2733" Cursor="Hand" MouseLeftButtonUp="ResultTab_Click">
                                    <TextBlock Text="RESULT" FontSize="11" FontWeight="Bold" Foreground="#E6EDF3"/>
                                </Border>
                                <Border x:Name="H2HTabBtn" CornerRadius="5" Padding="14,5" Background="Transparent" Cursor="Hand" MouseLeftButtonUp="H2HTab_Click" Margin="2,0,0,0">
                                    <TextBlock Text="HEAD TO HEAD" FontSize="11" FontWeight="Bold" Foreground="#6B7684"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- header -->
                <Grid Grid.Row="1" Margin="2,0,2,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <!-- Country flag (vector), matching the cards; the code chip is the fallback. -->
                            <Border x:Name="DFlag" CornerRadius="3" VerticalAlignment="Center" Margin="0,0,11,0" BorderBrush="#3A4552" BorderThickness="1" Visibility="Collapsed">
                                <Rectangle x:Name="DFlagRect" Width="27" Height="18" RadiusX="2" RadiusY="2"/>
                            </Border>
                            <Border x:Name="DCountry" Background="#1C2733" CornerRadius="5" Padding="7,2" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed">
                                <TextBlock x:Name="DCountryText" FontSize="12" FontFamily="Consolas" FontWeight="Bold" Foreground="#9BA7B4"/>
                            </Border>
                            <TextBlock x:Name="DName" FontSize="24" FontWeight="Bold" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="DSub" FontSize="12" Foreground="#6B7684" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <StackPanel Margin="0,0,22,0"><TextBlock Text="FINISH" FontSize="11" Foreground="#4A5460"/><TextBlock x:Name="DFinish" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#E6EDF3"/></StackPanel>
                        <StackPanel Margin="0,0,22,0"><TextBlock Text="GRID" FontSize="11" Foreground="#4A5460"/><TextBlock x:Name="DGrid" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#E6EDF3"/></StackPanel>
                        <StackPanel Margin="0,0,22,0"><TextBlock Text="GAINED" FontSize="11" Foreground="#4A5460"/><TextBlock x:Name="DGained" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#E6EDF3"/></StackPanel>
                        <StackPanel Margin="0,0,22,0"><TextBlock Text="POINTS" FontSize="11" Foreground="#4A5460"/><TextBlock x:Name="DPoints" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#E6EDF3"/></StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource MiniAction}" Width="34" Height="34" Click="DetailDelete_Click" ToolTip="Delete" Margin="0,0,8,0">
                                <Path Data="M3,6 H21 M8,6 V4 A1,1 0 0 1 9,3 H15 A1,1 0 0 1 16,4 V6 M18,6 V20 A2,2 0 0 1 16,22 H8 A2,2 0 0 1 6,20 V6"
                                      Stroke="#9BA7B4" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource PillButton}" Click="DetailExport_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12,15 V3 M7,8 L12,3 L17,8 M5,15 V19 A2,2 0 0 0 7,21 H17 A2,2 0 0 0 19,19 V15"
                                          Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="15" Height="15" Stretch="Uniform" Margin="0,0,7,0"/>
                                    <TextBlock Text="Export HTML" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- DNF strip -->
                <Border x:Name="DnfStrip" Grid.Row="2" Background="#1A1113" BorderBrush="#5A2323" BorderThickness="1" CornerRadius="10"
                        Padding="14" Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="DID NOT FINISH" FontSize="11" FontWeight="Bold" Foreground="#FF8080" Margin="0,0,0,4"/>
                        <TextBlock x:Name="DnfText" FontSize="13" Foreground="#9BA7B4"/>
                    </StackPanel>
                </Border>

                <!-- body: classification | (strategy + laps). Swapped wholesale for the H2H body
                     below rather than having H2H squeeze in beside it - both columns here are
                     already full and the page must not scroll. -->
                <Grid x:Name="ResultBody" Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT column: final classification (scrolls) with the penalties summary
                         card beneath it, so the long list sits at the top of the column and the
                         short summary aligns with the tyre-strategy card on the right. -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                    <!-- classification. Header + rows share one set of fixed column widths so
                         every column lines up; a right margin on both leaves room for the
                         scrollbar gutter so the header stays aligned with the rows. -->
                    <Border Grid.Row="0" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="FINAL CLASSIFICATION" FontSize="12" Foreground="#6B7684" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <Grid Grid.Row="1" Margin="6,0,14,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="74"/>
                                    <ColumnDefinition Width="62"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#" FontSize="11" Foreground="#4A5460"/>
                                <TextBlock Grid.Column="1" Text="DRIVER" FontSize="11" Foreground="#4A5460"/>
                                <TextBlock Grid.Column="2" Text="GAP" FontSize="11" Foreground="#4A5460" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="3" Text="BEST" FontSize="11" Foreground="#4A5460" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="4" Text="STINTS" FontSize="11" Foreground="#4A5460" Margin="6,0,0,0"/>
                            </Grid>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                                <ItemsControl x:Name="ClassList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="5" Padding="6,8,8,8" Margin="0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPlayer}" Value="True"><Setter Property="Background" Value="#1B2A42"/></DataTrigger>
                                                        </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="24"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="80"/>
                                                            <ColumnDefinition Width="74"/>
                                                            <ColumnDefinition Width="62"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding PositionText}" FontFamily="Consolas" FontWeight="Bold" FontSize="14" Foreground="{Binding PositionBrush}" VerticalAlignment="Center"/>
                                                        <!-- Driver on one line: dot + surname + fastest-lap mark, then the team
                                                             name inline to the right (fills the remaining width and trims). Single
                                                             row height lets all cars fit without a scrollbar. -->
                                                        <Grid Grid.Column="1" VerticalAlignment="Center">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Grid.Column="0" Width="8" Height="8" CornerRadius="2" Background="{Binding LiveryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding DriverName}" FontSize="14" Foreground="{Binding NameBrush}" VerticalAlignment="Center"/>
                                                            <!-- Fastest-lap badge, matching the race tower: purple disc + stopwatch glyph. -->
                                                            <Border Grid.Column="2" Width="15" Height="15" CornerRadius="7.5" Background="#AFA9EC" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                    Visibility="{Binding HasFastestLap, Converter={StaticResource BoolToVis}}">
                                                                <Viewbox Width="10" Height="10">
                                                                    <Canvas Width="24" Height="24">
                                                                        <Ellipse Canvas.Left="5" Canvas.Top="6" Width="14" Height="14" Stroke="#0D1117" StrokeThickness="2"/>
                                                                        <Path Data="M12,6 L12,3" Stroke="#0D1117" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                                        <Path Data="M12,13 L15,10" Stroke="#0D1117" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                                                    </Canvas>
                                                                </Viewbox>
                                                            </Border>
                                                            <TextBlock Grid.Column="3" Text="{Binding TeamName}" FontSize="12" Foreground="{Binding TeamBrush}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="8,1,0,0"
                                                                       Visibility="{Binding HasTeam, Converter={StaticResource BoolToVis}}"/>
                                                        </Grid>
                                                        <TextBlock Grid.Column="2" Text="{Binding GapText}" Foreground="{Binding GapBrush}" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding BestLapText}" Foreground="{Binding BestLapBrush}" FontFamily="Consolas" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                                                        <ItemsControl Grid.Column="4" ItemsSource="{Binding StintChips}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="6,0,0,0">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Width="15" Height="15" CornerRadius="7.5" Background="{Binding Brush}" Margin="0,0,3,0">
                                                                        <TextBlock Text="{Binding Letter}" Foreground="{Binding TextBrush}" FontSize="9" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Penalties summary: mirrors the live Penalties &amp; Flags widget (its
                         penalties half - live flags are dropped, being meaningless post-race).
                         Same quiet convention: a clean race shows a green tick, not an empty card. -->
                    <!-- MinHeight fits the penalties list at its cap (6 entries = 3 rows of 2);
                         the tyre-strategy card opposite carries the same MinHeight so the two
                         bottom cards stay the same size and aligned. -->
                    <!-- DataContext is set to the SavedRaceView in ShowSession (code-behind): the
                         rest of the detail view is populated imperatively, but this card is the one
                         part driven by {Binding}, so it needs the view model as its context or its
                         NoPenalties/HasPenalties/Penalties bindings silently fail (which is exactly
                         why the card used to always read "No penalties" regardless of the data). -->
                    <Border x:Name="PenaltiesCard" Grid.Row="1" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,16,0,0" MinHeight="156">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="PENALTIES" FontSize="12" Foreground="#6B7684" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Visibility="{Binding NoPenalties, Converter={StaticResource BoolToVis}}">
                                <Viewbox Width="16" Height="16" Margin="0,0,9,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="{StaticResource CheckmarkGeometry}" Stroke="#97C459" StrokeThickness="2.4"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="No penalties" FontSize="13" Foreground="#9BA7B4" VerticalAlignment="Center"/>
                            </StackPanel>

                            <ItemsControl ItemsSource="{Binding Penalties}" Visibility="{Binding HasPenalties, Converter={StaticResource BoolToVis}}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="2"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- red = penalty, amber = warning (see PenaltyEntry) -->
                                        <Border Background="{Binding Background}" CornerRadius="6" Padding="10,7" Margin="0,0,6,6">
                                            <TextBlock Text="{Binding Text}" FontSize="13.5" Foreground="{Binding Foreground}" TextTrimming="CharacterEllipsis"/>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Border>
                    </Grid>

                    <!-- RIGHT column: lap-by-lap (scrolls) on top, tyre-strategy card beneath. -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

                        <Border Grid.Row="1" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,16,0,0" MinHeight="156">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="YOUR TYRE STRATEGY" FontSize="12" Foreground="#6B7684" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                    <Grid Height="26">
                                        <Border Background="#1C2733" CornerRadius="4"/>
                                        <Grid x:Name="DetailStintBar"/>
                                    </Grid>
                                    <Canvas x:Name="DetailStintTicks" Height="16" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="YOUR LAP-BY-LAP" FontSize="12" Foreground="#6B7684" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                <!-- header shares the row columns; sectors/pit/time right-aligned so digits line up -->
                                <Grid Grid.Row="1" Margin="2,0,14,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="82"/>
                                        <ColumnDefinition Width="78"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="LAP" FontSize="11" Foreground="#4A5460"/>
                                    <TextBlock Grid.Column="1" Text="S1" FontSize="11" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="S2" FontSize="11" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="S3" FontSize="11" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="PIT" FontSize="11" Foreground="#4A5460" HorizontalAlignment="Right" Margin="0,0,18,0"/>
                                    <TextBlock Grid.Column="5" Text="TIME" FontSize="11" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="6" Text="DELTA" FontSize="11" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                </Grid>

                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                                    <ItemsControl x:Name="LapList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="2,8,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="88"/>
                                                        <ColumnDefinition Width="64"/>
                                                        <ColumnDefinition Width="64"/>
                                                        <ColumnDefinition Width="64"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="82"/>
                                                        <ColumnDefinition Width="78"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding LapText}" FontFamily="Consolas" FontSize="14" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding S1Text}" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="{Binding S1Brush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding S2Text}" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="{Binding S2Brush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding S3Text}" FontFamily="Consolas" FontSize="13" FontWeight="Bold" Foreground="{Binding S3Brush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    <!-- EVENTS (left) share the middle gap with the pit/tag (right): SC/VSC, red
                                                         flag, chequered and penalty chips for this lap. Empty on a green lap. -->
                                                    <ItemsControl Grid.Column="4" ItemsSource="{Binding Events}" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="30,0,0,0">
                                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate><DataTemplate><widgets:LapEventChip/></DataTemplate></ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <!-- PIT cell: pit time then the IN/OUT tag, with the TAG kept rightmost (fixed
                                                         width slot) so IN and OUT line up in the same column whether or not a pit
                                                         time is present. Matches the main Lap History widget's pit/tag ordering. -->
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0">
                                                        <TextBlock Text="{Binding PitText}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="#79C0FF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <Border Width="30" VerticalAlignment="Center" Visibility="{Binding HasTag, Converter={StaticResource BoolToVis}}">
                                                            <Border Background="#1C2733" CornerRadius="4" Padding="4,1" HorizontalAlignment="Right">
                                                                <TextBlock Text="{Binding Tag}" FontSize="10.5" FontWeight="Bold" Foreground="#9BA7B4"/>
                                                            </Border>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="5" Text="{Binding LapTimeText}" FontFamily="Consolas" FontSize="15" FontWeight="Bold" Foreground="{Binding LapTimeBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="6" Text="{Binding DeltaText}" FontFamily="Consolas" FontSize="13" Foreground="#6B7684" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <!-- ============ HEAD TO HEAD BODY ============
                     Swaps in for ResultBody above (never sits beside it). Mirrors the same 50/50
                     split so the page reads as the same shape: left is who won and by what, right
                     is how it unfolded. Nothing here scrolls except the tape, which only would on
                     a very short window. -->
                <Grid x:Name="H2HBody" Grid.Row="3" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- ONE grid owns the rows for BOTH columns, and each column holds exactly TWO
                         cards, so tops and bottoms align by construction. The verdict and the tape
                         are deliberately one card rather than two: they answer the same question
                         at two levels of detail, and merging them made the column counts match
                         (2 v 2) so the bottom pair - PIT STOPS and STRATEGY - line up without any
                         row-spanning trickery. With separate grids per column the bottom cards
                         had drifted 14px out of line. -->
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                        <!-- LEFT COLUMN. The TAPE takes the leftover height (row 1, *) and the
                             stops card sizes to its content. The other way round left the stops
                             card mostly empty with its total stranded far below the rows. The
                             stops list still scrolls inside its own bounded height, so a
                             five-stop wet race can't push the page past its fixed size.

                             Verdict: the one-line answer, so who won doesn't have to be read out
                             of a table of numbers. -->
                        <!-- Top-aligned and content-sized. Stretching it to fill the row left a
                             large void inside the card under the last row; the leftover height is
                             better spent on the gap chart opposite, which actually uses it. -->
                        <!-- Stretches to fill the row, so its bottom edge meets the pit-stops card
                             below and lines up with the gap chart opposite - all four cards then
                             share the same two horizontal edges. The empty space sits INSIDE the
                             card, below the last row, and is reserved for further head-to-head
                             content. (Spreading the rows to fill it instead was tried and rejected
                             as too airy.) -->
                        <Border Grid.Row="0" Grid.Column="0" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="H2HYouName" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <Border x:Name="H2HYouLivery" Width="3" Height="15" CornerRadius="1.5" Margin="0,0,7,0"/>
                                            <TextBlock x:Name="H2HYouResult" FontSize="17" FontWeight="Bold" FontFamily="Consolas" Foreground="#E6EDF3"/>
                                            <TextBlock x:Name="H2HYouPoints" FontSize="11" Foreground="#6B7684" VerticalAlignment="Bottom" Margin="8,0,0,2"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock x:Name="H2HVerdict" Grid.Column="1" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" Margin="14,0"/>

                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                        <TextBlock x:Name="H2HRivalName" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0" HorizontalAlignment="Right">
                                            <TextBlock x:Name="H2HRivalPoints" FontSize="11" Foreground="#6B7684" VerticalAlignment="Bottom" Margin="0,0,8,2"/>
                                            <TextBlock x:Name="H2HRivalResult" FontSize="17" FontWeight="Bold" FontFamily="Consolas" Foreground="#E6EDF3"/>
                                            <Border x:Name="H2HRivalLivery" Width="3" Height="15" CornerRadius="1.5" Margin="7,0,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="H2HMargin" FontSize="11" Foreground="#6B7684" HorizontalAlignment="Center" Margin="0,9,0,0"/>
                                </StackPanel>

                                <!-- Separator, not a second card: the verdict and the tape are the
                                     same comparison at two levels of detail. The verdict already
                                     names both drivers over their own sides, so the tape needs no
                                     repeated header - just the centred title. -->
                                <Grid Grid.Row="1" Margin="0,14,0,10">
                                    <Border BorderBrush="#232B35" BorderThickness="0,1,0,0" VerticalAlignment="Center"/>
                                    <Border Background="#161B22" HorizontalAlignment="Center" Padding="10,0">
                                        <TextBlock Text="TALE OF THE TAPE" FontSize="12" Foreground="#6B7684" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl x:Name="TapeList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Broadcast "tale of the tape" structure: each
                                                     driver's numbers on their OWN side of the card
                                                     and the metric name centred between them. The
                                                     previous label-left / value / value layout put
                                                     both drivers' numbers in the middle-right and
                                                     read as one messy block - here the two sides
                                                     mirror the verdict banner above, so which
                                                     column belongs to whom needs no explaining.
                                                     The centre column is a fixed width so every
                                                     label lands on the same axis regardless of
                                                     value widths, and the delta right-aligns
                                                     inside that same column so it never nudges a
                                                     label off centre. -->
                                                <!-- MaxWidth keeps the two drivers' numbers a
                                                     readable distance apart. Without it they pin
                                                     to the card edges, which on a maximised window
                                                     put them ~900px apart - far enough that the
                                                     eye can't pair a value with its opposite. -->
                                                <Grid Margin="0,0,0,7" MaxWidth="620" HorizontalAlignment="Center">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="176"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding YouText}" Foreground="{Binding YouBrush}" FontFamily="Consolas" FontSize="13"
                                                               HorizontalAlignment="Left" VerticalAlignment="Center"/>

                                                    <!-- Label with the delta directly beneath it,
                                                         both centred. The delta belongs to neither
                                                         driver, so it sits on the centre axis
                                                         rather than beside a value - right-aligning
                                                         it in this column ran it straight into the
                                                         rival's number ("0.2001:37.522"). -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <!-- Indent marks S1/S2/S3 as a breakdown of the
                                                             IDEAL LAP row above, not peers of it. -->
                                                        <TextBlock Text="{Binding Label}" FontSize="11" Foreground="#6B7684"
                                                                   HorizontalAlignment="Center" Margin="{Binding LabelIndent}"/>
                                                        <TextBlock Text="{Binding DeltaText}" Foreground="{Binding DeltaBrush}" FontFamily="Consolas" FontSize="10"
                                                                   HorizontalAlignment="Center"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Column="2" Text="{Binding RivalText}" Foreground="{Binding RivalBrush}" FontFamily="Consolas" FontSize="13"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <!-- PIT STOPS. One column per driver, each listing its own stops - stops
                             land on different laps, so a shared lap column would be mostly gaps.
                             The list scrolls inside this card, so a wet race with five stops can
                             never push the page past its fixed height. -->
                        <Border Grid.Row="1" Grid.Column="0" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,16,0,0">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <TextBlock Text="PIT STOPS" FontSize="12" Foreground="#6B7684" FontWeight="SemiBold"/>
                                    <TextBlock Text="lap · box · lane" FontSize="10" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                </Grid>

                                <Grid Grid.Row="1">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="StopsYouName" FontSize="11" FontWeight="Bold" Foreground="#8B97A4" Margin="0,0,0,6" TextTrimming="CharacterEllipsis"/>
                                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="StopsYouList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,5">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding LapText}" FontSize="11" FontFamily="Consolas" Foreground="#6B7684"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding BoxText}" FontSize="12" FontFamily="Consolas" Foreground="#79C0FF" HorizontalAlignment="Right"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding LaneText}" FontSize="11" FontFamily="Consolas" Foreground="#6B7684" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <TextBlock x:Name="StopsYouEmpty" Text="No stops" FontSize="11" Foreground="#4A5460" Visibility="Collapsed"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock x:Name="StopsRivalName" FontSize="11" FontWeight="Bold" Foreground="#8B97A4" Margin="0,0,0,6" TextTrimming="CharacterEllipsis"/>
                                        <ScrollViewer MaxHeight="120" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="StopsRivalList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,5">
                                                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding LapText}" FontSize="11" FontFamily="Consolas" Foreground="#6B7684"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding BoxText}" FontSize="12" FontFamily="Consolas" Foreground="#79C0FF" HorizontalAlignment="Right"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding LaneText}" FontSize="11" FontFamily="Consolas" Foreground="#6B7684" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <TextBlock x:Name="StopsRivalEmpty" Text="No stops" FontSize="11" Foreground="#4A5460" Visibility="Collapsed"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Total box time: the single number that says who lost more in the pits. -->
                                <Grid Grid.Row="2" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#232B35" BorderThickness="0,1,0,0" Padding="0,6,0,0">
                                        <!-- Column widths mirror the stop rows above (36 / * / *)
                                             so the total lands under the BOX times it sums.
                                             Right-aligning it across the whole width put it under
                                             the LANE column, totalling a number it isn't. -->
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="TOTAL BOX" FontSize="10" Foreground="#4A5460" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="StopsYouTotal" Grid.Column="1" FontSize="12" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                    <Border Grid.Column="2" BorderBrush="#232B35" BorderThickness="0,1,0,0" Padding="0,6,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Grid.ColumnSpan="2" Text="TOTAL BOX" FontSize="10" Foreground="#4A5460" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="StopsRivalTotal" Grid.Column="1" FontSize="12" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    <!-- RIGHT COLUMN. The gap chart spans rows 0-1 so it stands opposite the
                         verdict + tape as one tall card, and STRATEGY shares row 2 with the pit
                         stops card - which is what keeps the two bottom cards level. -->
                    <Border Grid.Row="0" Grid.Column="2" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <TextBlock Text="GAP EVOLUTION" FontSize="12" Foreground="#6B7684" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="GapLegend" FontSize="10" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                </Grid>
                                <!-- Drawn in code-behind, vector, on resize - "drawn, not captured". -->
                                <Canvas x:Name="GapCanvas" Grid.Row="1" ClipToBounds="True" SizeChanged="GapCanvas_SizeChanged"/>
                                <TextBlock x:Name="GapEmpty" Grid.Row="1" Text="No lap data captured for both drivers."
                                           Foreground="#4A5460" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                <Canvas x:Name="GapAxis" Grid.Row="2" Height="16" Margin="0,5,0,0"/>
                            </Grid>
                        </Border>

                    <Border Grid.Row="1" Grid.Column="2" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="STRATEGY" FontSize="12" Foreground="#6B7684" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <!-- Each bar carries its OWN lap axis. A single shared axis would
                                     draw only one driver's pit markers and silently present them
                                     as if they applied to both. -->
                                <TextBlock x:Name="H2HStintYouLabel" FontSize="11" Foreground="#8B97A4" Margin="0,0,0,4"/>
                                <Grid x:Name="H2HStintYou" Height="14" Loaded="H2HStintYou_Loaded"/>
                                <Canvas x:Name="H2HTicksYou" Height="16" Margin="0,4,0,0"/>

                                <TextBlock x:Name="H2HStintRivalLabel" FontSize="11" Foreground="#8B97A4" Margin="0,14,0,4"/>
                                <Grid x:Name="H2HStintRival" Height="14" Loaded="H2HStintRival_Loaded"/>
                                <Canvas x:Name="H2HTicksRival" Height="16" Margin="0,4,0,0"/>
                            </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ============ DELETE CONFIRM ============ -->
            <Border x:Name="ConfirmOverlay" Background="#0D1117E6" Visibility="Collapsed">
                <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="10" Padding="24"
                        HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
                    <StackPanel>
                        <TextBlock x:Name="ConfirmText" TextWrapping="Wrap" TextAlignment="Center" Foreground="#E6EDF3" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                            <Button Content="Keep" Click="ConfirmCancel_Click" Cursor="Hand" Foreground="#9BA7B4" Background="#161B22" Padding="16,7" Margin="0,0,10,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="16,7"><ContentPresenter/></Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Delete" Click="ConfirmDelete_Click" Cursor="Hand" Foreground="#FF8080">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#3A1417" BorderBrush="#5A2323" BorderThickness="1" CornerRadius="6" Padding="16,7"><ContentPresenter/></Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#4A181C"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ============ TOAST ============ -->
            <Border x:Name="Toast" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8"
                    Padding="12,10" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10" Visibility="Collapsed">
                <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="3" Opacity="0.5"/></Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Width="3" Background="#97C459" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock x:Name="ToastText" Foreground="#E6EDF3" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
