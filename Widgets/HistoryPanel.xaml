<UserControl x:Class="F1RaceEngineer.Widgets.HistoryPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600">

    <UserControl.Resources>
        <!-- Flat card button: the whole GP card is clickable to open its detail. -->
        <Style x:Key="HistoryCardButton" TargetType="Button">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="BorderBrush" Value="#232B35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#171D26"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#31445C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small icon action (export / delete) shown on card hover and in the detail header. -->
        <Style x:Key="MiniAction" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Background" Value="#0D1117"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#9BA7B4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="#30363D"
                                BorderThickness="1" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3D4A5C"/>
                                <Setter Property="Foreground" Value="#E6EDF3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background" Value="#1F6FEB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2B7BF5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="#0D1117">
        <Grid Margin="16">

            <!-- ============ LIST VIEW ============ -->
            <Grid x:Name="ListRoot">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="2,0,2,14">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                        <TextBlock Text="RACE HISTORY" FontSize="15" FontWeight="Bold" Foreground="#E6EDF3"/>
                        <TextBlock x:Name="CountText" FontSize="12" Foreground="#6B7684" Margin="12,0,0,1" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock Text="Sorted by most recent" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                               FontSize="11" Foreground="#6B7684"/>
                </Grid>

                <TextBlock x:Name="EmptyState" Grid.Row="1" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360"
                           Text="No saved races yet. Finish a race with the app connected and it appears here automatically."
                           Foreground="#5A6470" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                    <ItemsControl x:Name="RaceList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button x:Name="CardBtn" Style="{StaticResource HistoryCardButton}" Margin="0,0,12,12" Click="Card_Click" Tag="{Binding}">
                                    <Grid Margin="15,14">
                                        <!-- teal accent bar -->
                                        <Border HorizontalAlignment="Left" Width="3" Background="#37BEDD" CornerRadius="2"
                                                Margin="-15,-14,0,-14"/>

                                        <StackPanel>
                                            <Grid>
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Background="#1C2733" CornerRadius="4" Padding="5,1" VerticalAlignment="Center" Margin="0,0,8,0"
                                                                Visibility="{Binding HasCountry, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="{Binding Country}" FontSize="10" FontFamily="Consolas" FontWeight="Bold" Foreground="#9BA7B4"/>
                                                        </Border>
                                                        <TextBlock Text="{Binding GrandPrix}" FontSize="16" FontWeight="Bold" Foreground="#E6EDF3" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding CardSubtitle}" FontSize="11" Foreground="#6B7684" Margin="0,3,0,0"/>
                                                </StackPanel>
                                                <StackPanel HorizontalAlignment="Right" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding FinishText}" Foreground="{Binding FinishBrush}" FontFamily="Consolas"
                                                               FontWeight="Bold" FontSize="24" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding DeltaText}" Foreground="{Binding DeltaBrush}" FontFamily="Consolas"
                                                               FontSize="11" HorizontalAlignment="Right" Margin="0,2,0,0"
                                                               Visibility="{Binding HasDelta, Converter={StaticResource BoolToVis}}"/>
                                                </StackPanel>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,13,0,0" VerticalAlignment="Center">
                                                <StackPanel Margin="0,0,20,0">
                                                    <TextBlock Text="BEST LAP" FontSize="9.5" Foreground="#4A5460"/>
                                                    <TextBlock Text="{Binding BestLapText}" FontSize="13" FontFamily="Consolas" Foreground="{Binding BestLapBrush}"/>
                                                </StackPanel>
                                                <StackPanel Margin="0,0,20,0">
                                                    <TextBlock Text="STOPS" FontSize="9.5" Foreground="#4A5460"/>
                                                    <TextBlock Text="{Binding StopsText}" FontSize="13" FontFamily="Consolas" Foreground="#E6EDF3"/>
                                                </StackPanel>
                                                <TextBlock Text="◷ Fastest lap" Foreground="#AFA9EC" FontSize="10.5" FontWeight="Bold"
                                                           VerticalAlignment="Center" Margin="0,6,0,0"
                                                           Visibility="{Binding HasFastestLap, Converter={StaticResource BoolToVis}}"/>
                                                <StackPanel HorizontalAlignment="Right" Margin="12,0,0,0">
                                                    <TextBlock Text="{Binding PointsText}" FontSize="15" FontWeight="Bold" FontFamily="Consolas" Foreground="#E6EDF3" HorizontalAlignment="Right"/>
                                                    <TextBlock Text="POINTS" FontSize="9.5" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- mini stint bar (built in code-behind) -->
                                            <Grid x:Name="CardStint" Height="7" Margin="0,12,0,0" Loaded="CardStint_Loaded" Tag="{Binding}"/>
                                        </StackPanel>

                                        <!-- hover actions -->
                                        <StackPanel x:Name="CardActions" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top"
                                                    Margin="0,-4,-4,0" Opacity="0">
                                            <Button Style="{StaticResource MiniAction}" Click="Export_Click" Tag="{Binding}" ToolTip="Export as HTML" Margin="0,0,6,0">
                                                <Path Data="M12,15 V3 M7,8 L12,3 L17,8 M5,15 V19 A2,2 0 0 0 7,21 H17 A2,2 0 0 0 19,19 V15"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="14" Height="14" Stretch="Uniform"/>
                                            </Button>
                                            <Button Style="{StaticResource MiniAction}" Click="Delete_Click" Tag="{Binding}" ToolTip="Delete">
                                                <Path Data="M3,6 H21 M8,6 V4 A1,1 0 0 1 9,3 H15 A1,1 0 0 1 16,4 V6 M18,6 V20 A2,2 0 0 1 16,22 H8 A2,2 0 0 1 6,20 V6"
                                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="14" Height="14" Stretch="Uniform"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Button>
                                <DataTemplate.Triggers>
                                    <Trigger SourceName="CardBtn" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="CardActions" Property="Opacity" Value="1"/>
                                    </Trigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ============ DETAIL VIEW ============ -->
            <Grid x:Name="DetailRoot" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Button Grid.Row="0" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Foreground="#9BA7B4" Click="Back_Click" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M15,18 L9,12 L15,6" Stroke="#9BA7B4" StrokeThickness="2.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                        <TextBlock Text="All races" FontSize="12" Foreground="#9BA7B4"/>
                    </StackPanel>
                </Button>

                <!-- header -->
                <Grid Grid.Row="1" Margin="2,0,2,16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="DCountry" Background="#1C2733" CornerRadius="5" Padding="7,2" VerticalAlignment="Center" Margin="0,0,10,0" Visibility="Collapsed">
                                <TextBlock x:Name="DCountryText" FontSize="12" FontFamily="Consolas" FontWeight="Bold" Foreground="#9BA7B4"/>
                            </Border>
                            <TextBlock x:Name="DName" FontSize="24" FontWeight="Bold" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="DSub" FontSize="12" Foreground="#6B7684" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <StackPanel Margin="0,0,22,0"><TextBlock Text="FINISH" FontSize="10" Foreground="#4A5460"/><TextBlock x:Name="DFinish" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#E6EDF3"/></StackPanel>
                        <StackPanel Margin="0,0,22,0"><TextBlock Text="GRID" FontSize="10" Foreground="#4A5460"/><TextBlock x:Name="DGrid" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#E6EDF3"/></StackPanel>
                        <StackPanel Margin="0,0,22,0"><TextBlock Text="POINTS" FontSize="10" Foreground="#4A5460"/><TextBlock x:Name="DPoints" FontFamily="Consolas" FontSize="22" FontWeight="Bold" Foreground="#E6EDF3"/></StackPanel>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource MiniAction}" Width="34" Height="34" Click="DetailDelete_Click" ToolTip="Delete" Margin="0,0,8,0">
                                <Path Data="M3,6 H21 M8,6 V4 A1,1 0 0 1 9,3 H15 A1,1 0 0 1 16,4 V6 M18,6 V20 A2,2 0 0 1 16,22 H8 A2,2 0 0 1 6,20 V6"
                                      Stroke="#9BA7B4" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="16" Height="16" Stretch="Uniform"/>
                            </Button>
                            <Button Style="{StaticResource PillButton}" Click="DetailExport_Click">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="M12,15 V3 M7,8 L12,3 L17,8 M5,15 V19 A2,2 0 0 0 7,21 H17 A2,2 0 0 0 19,19 V15"
                                          Stroke="White" StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Width="15" Height="15" Stretch="Uniform" Margin="0,0,7,0"/>
                                    <TextBlock Text="Export HTML" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- DNF strip -->
                <Border x:Name="DnfStrip" Grid.Row="2" Background="#1A1113" BorderBrush="#5A2323" BorderThickness="1" CornerRadius="10"
                        Padding="14" Margin="0,0,0,16" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="DID NOT FINISH" FontSize="11" FontWeight="Bold" Foreground="#FF8080" Margin="0,0,0,4"/>
                        <TextBlock x:Name="DnfText" FontSize="13" Foreground="#9BA7B4"/>
                    </StackPanel>
                </Border>

                <!-- body: classification | (strategy + laps) -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.05*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="0.95*"/>
                    </Grid.ColumnDefinitions>

                    <!-- classification. Header + rows share one set of fixed column widths so
                         every column lines up; a right margin on both leaves room for the
                         scrollbar gutter so the header stays aligned with the rows. -->
                    <Border Grid.Column="0" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="FINAL CLASSIFICATION" FontSize="11" Foreground="#6B7684" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <Grid Grid.Row="1" Margin="6,0,14,7">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="74"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="78"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="#" FontSize="10" Foreground="#4A5460"/>
                                <TextBlock Grid.Column="1" Text="DRIVER" FontSize="10" Foreground="#4A5460"/>
                                <TextBlock Grid.Column="2" Text="BEST" FontSize="10" Foreground="#4A5460" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                                <TextBlock Grid.Column="3" Text="PIT" FontSize="10" Foreground="#4A5460" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="STINTS" FontSize="10" Foreground="#4A5460" Margin="6,0,0,0"/>
                            </Grid>

                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                                <ItemsControl x:Name="ClassList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="5" Padding="6,5,8,5" Margin="0,1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPlayer}" Value="True"><Setter Property="Background" Value="#1B2A42"/></DataTrigger>
                                                        </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="26"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="74"/>
                                                            <ColumnDefinition Width="40"/>
                                                            <ColumnDefinition Width="78"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding PositionText}" FontFamily="Consolas" FontWeight="Bold" FontSize="13" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <Border Width="8" Height="8" CornerRadius="2" Background="{Binding LiveryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Text="{Binding DriverName}" FontSize="12.5" Foreground="#E6EDF3" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="◷" Foreground="#AFA9EC" FontSize="12" Margin="5,0,0,0" VerticalAlignment="Center"
                                                                       Visibility="{Binding HasFastestLap, Converter={StaticResource BoolToVis}}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{Binding BestLapText}" Foreground="{Binding BestLapBrush}" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                                                        <TextBlock Grid.Column="3" Text="{Binding PitsText}" Foreground="#9BA7B4" FontFamily="Consolas" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        <ItemsControl Grid.Column="4" ItemsSource="{Binding StintChips}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="6,0,0,0">
                                                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Width="15" Height="15" CornerRadius="7.5" Background="{Binding Brush}" Margin="0,0,3,0">
                                                                        <TextBlock Text="{Binding Letter}" Foreground="{Binding TextBrush}" FontSize="9" FontWeight="Bold" FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- strategy + laps -->
                    <Grid Grid.Column="2">
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

                        <Border Grid.Row="0" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="YOUR TYRE STRATEGY" FontSize="11" Foreground="#6B7684" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <Grid x:Name="DetailStintBar" Height="26"/>
                                <Grid x:Name="DetailStintTicks" Height="16" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Background="#161B22" BorderBrush="#232B35" BorderThickness="1" CornerRadius="10" Padding="14">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="YOUR LAP-BY-LAP" FontSize="11" Foreground="#6B7684" FontWeight="SemiBold" Margin="0,0,0,10"/>

                                <!-- header shares the row columns; sectors/pit/time right-aligned so digits line up -->
                                <Grid Grid.Row="1" Margin="2,0,14,7">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="88"/>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="64"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="82"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="LAP" FontSize="10" Foreground="#4A5460"/>
                                    <TextBlock Grid.Column="1" Text="S1" FontSize="10" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="S2" FontSize="10" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="S3" FontSize="10" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="4" Text="PIT" FontSize="10" Foreground="#4A5460" HorizontalAlignment="Right" Margin="0,0,18,0"/>
                                    <TextBlock Grid.Column="5" Text="TIME" FontSize="10" Foreground="#4A5460" HorizontalAlignment="Right"/>
                                </Grid>

                                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                                    <ItemsControl x:Name="LapList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="2,5,0,5">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="88"/>
                                                        <ColumnDefinition Width="64"/>
                                                        <ColumnDefinition Width="64"/>
                                                        <ColumnDefinition Width="64"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="82"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding LapText}" FontFamily="Consolas" FontSize="13" Foreground="#E6EDF3" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding S1Text}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{Binding S1Brush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding S2Text}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{Binding S2Brush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding S3Text}" FontFamily="Consolas" FontSize="12" FontWeight="Bold" Foreground="{Binding S3Brush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                    <!-- PIT cell: pit time then the IN/OUT tag, with the TAG kept rightmost (fixed
                                                         width slot) so IN and OUT line up in the same column whether or not a pit
                                                         time is present. Matches the main Lap History widget's pit/tag ordering. -->
                                                    <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0">
                                                        <TextBlock Text="{Binding PitText}" FontFamily="Consolas" FontSize="11" FontWeight="Bold" Foreground="#79C0FF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                        <Border Width="30" VerticalAlignment="Center" Visibility="{Binding HasTag, Converter={StaticResource BoolToVis}}">
                                                            <Border Background="#1C2733" CornerRadius="4" Padding="4,1" HorizontalAlignment="Right">
                                                                <TextBlock Text="{Binding Tag}" FontSize="10" FontWeight="Bold" Foreground="#9BA7B4"/>
                                                            </Border>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="5" Text="{Binding LapTimeText}" FontFamily="Consolas" FontSize="14" FontWeight="Bold" Foreground="{Binding LapTimeBrush}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ============ DELETE CONFIRM ============ -->
            <Border x:Name="ConfirmOverlay" Background="#0D1117E6" Visibility="Collapsed">
                <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="10" Padding="24"
                        HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="360">
                    <StackPanel>
                        <TextBlock x:Name="ConfirmText" TextWrapping="Wrap" TextAlignment="Center" Foreground="#E6EDF3" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,0">
                            <Button Content="Keep" Click="ConfirmCancel_Click" Cursor="Hand" Foreground="#9BA7B4" Background="#161B22" Padding="16,7" Margin="0,0,10,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="6" Padding="16,7"><ContentPresenter/></Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Content="Delete" Click="ConfirmDelete_Click" Cursor="Hand" Foreground="#FF8080">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="#3A1417" BorderBrush="#5A2323" BorderThickness="1" CornerRadius="6" Padding="16,7"><ContentPresenter/></Border>
                                        <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#4A181C"/></Trigger></ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ============ TOAST ============ -->
            <Border x:Name="Toast" Background="#161B22" BorderBrush="#30363D" BorderThickness="1" CornerRadius="8"
                    Padding="12,10" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10" Visibility="Collapsed">
                <Border.Effect><DropShadowEffect Color="#000000" BlurRadius="16" ShadowDepth="3" Opacity="0.5"/></Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Width="3" Background="#97C459" CornerRadius="2" Margin="0,0,10,0"/>
                    <TextBlock x:Name="ToastText" Foreground="#E6EDF3" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
