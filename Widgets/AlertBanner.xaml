<UserControl x:Class="F1RaceEngineer.Widgets.AlertBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <Border Background="{Binding AlertBackgroundBrush}" CornerRadius="6" Padding="16,14"
            Margin="0,0,0,12"
            Visibility="{Binding AlertVisible, Converter={StaticResource BoolToVis}}">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Viewbox Width="20" Height="30" Margin="0,0,12,0">
                <Canvas Width="16" Height="24">
                    <Path Data="{StaticResource FlagPoleGeometry}" Stroke="{Binding AlertTextBrush}" StrokeThickness="2"/>
                    <Path Data="{StaticResource FlagPennantGeometry}" Fill="{Binding AlertTextBrush}"/>
                </Canvas>
            </Viewbox>
            <TextBlock Text="{Binding AlertText}" FontSize="28" FontWeight="Bold"
                       Foreground="{Binding AlertTextBrush}" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
