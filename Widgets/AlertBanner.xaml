<UserControl x:Class="F1RaceEngineer.Widgets.AlertBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">

    <!-- Broadcast-style status strip: floats over the TOP of the right column (see
         MainWindow.xaml) rather than sitting in the layout flow, so showing/hiding it
         never pushes the widgets below around. The drop shadow lifts it off the content
         it overlays so it reads as a floating overlay, not another stacked card.
         The opaque strip fully covers the current-lap / PB / delta block underneath it -
         deliberate, since during a Safety Car / VSC / red flag those lap times are
         irrelevant. Its height comes from MainWindow, which binds this control's MinHeight
         to LapTimingWidget.HeaderExtent (that block's real measured height) - so there's no
         hand-measured constant here to fall out of sync when font sizes change. -->
    <Border Background="{Binding AlertBackgroundBrush}" CornerRadius="6" Padding="16,10"
            Visibility="{Binding AlertVisible, Converter={StaticResource BoolToVis}}">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="3" Opacity="0.5" Direction="270"/>
        </Border.Effect>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Viewbox Width="16" Height="24" Margin="0,0,10,0">
                <Canvas Width="16" Height="24">
                    <Path Data="{StaticResource FlagPoleGeometry}" Stroke="{Binding AlertTextBrush}" StrokeThickness="2"/>
                    <Path Data="{StaticResource FlagPennantGeometry}" Fill="{Binding AlertTextBrush}"/>
                </Canvas>
            </Viewbox>
            <TextBlock Text="{Binding AlertText}" FontSize="22" FontWeight="Bold"
                       Foreground="{Binding AlertTextBrush}" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
