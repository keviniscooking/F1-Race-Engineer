<UserControl x:Class="F1RaceEngineer.Widgets.PositionListWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="480">

    <Border Style="{StaticResource WidgetCardStyle}">
        <StackPanel>
            <TextBlock Text="POSITION" FontSize="11" Foreground="#6B7684" Margin="0,0,0,8"/>

            <Grid Margin="6,0,6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="26"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="#" FontSize="10.5" Foreground="#4A5460"/>
                <TextBlock Grid.Column="2" Text="Driver" FontSize="10.5" Foreground="#4A5460" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="3" Text="Best" FontSize="10.5" Foreground="#4A5460" HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="4" Text="Gap" FontSize="10.5" Foreground="#4A5460" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Qualifying always shows the full field (up to 22 rows) - the original
                 spacious row style (padding "6,5", 15px text, two full text lines) meant
                 22 rows regularly overflowed the window, forcing the whole page to scroll
                 just to see the player's own row near the back of the grid. Compacted to
                 the same density as the Race Position Tower, which solves the identical
                 22-row problem, so the whole field fits without scrolling in the common
                 case. -->
            <ItemsControl ItemsSource="{Binding PositionList}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="6,3" CornerRadius="4" Margin="0,0.5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                            <Setter Property="Background" Value="#1C2733"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="26"/>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Position}" FontSize="13" FontWeight="Bold" Foreground="#E6EDF3" FontFamily="Consolas"/>
                                <Border Grid.Column="1" Width="8" Height="8" CornerRadius="2" Background="{Binding LiveryBrush}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DriverName}" FontSize="13" Foreground="#E6EDF3"/>
                                    <TextBlock Text="{Binding TeamName}" FontSize="9.5" Foreground="#6B7684"/>
                                </StackPanel>
                                <TextBlock Grid.Column="3" Text="{Binding BestLapText}" FontSize="13" Foreground="#E6EDF3" FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{Binding GapText}" FontSize="13" Foreground="#6B7684" FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
