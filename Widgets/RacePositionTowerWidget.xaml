<UserControl x:Class="F1RaceEngineer.Widgets.RacePositionTowerWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400">

    <Border Style="{StaticResource WidgetCardStyle}">
        <StackPanel>
            <!-- Own distinct bar, matching how the real broadcast graphic layers the lap
                 counter as its own segment above the entrant list, rather than folding it
                 into the "POSITION" caption row. -->
            <Border Background="#1C2733" CornerRadius="6" Padding="0,8" Margin="0,0,0,10">
                <TextBlock Text="{Binding LapCounterText}" FontSize="16" FontWeight="Bold" Foreground="#E6EDF3" HorizontalAlignment="Center"/>
            </Border>

            <!-- Broadcast-style purple "FASTEST LAP" strip: reuses the same purple (#AFA9EC)
                 and stopwatch glyph as the per-row fastest-lap badge below, so the two read
                 as the same concept. Hidden until someone has actually set a lap (nobody has
                 at lights-out). Sits directly under the lap counter, where the eye already
                 goes for race-wide info. -->
            <Border Background="#1B182B" CornerRadius="6" Padding="9,6" Margin="0,0,0,10"
                    Visibility="{Binding HasRaceFastestLap, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="18" Height="18" CornerRadius="9" Background="#AFA9EC" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Viewbox Width="12" Height="12">
                            <Canvas Width="24" Height="24">
                                <Ellipse Canvas.Left="5" Canvas.Top="6" Width="14" Height="14" Stroke="#0D1117" StrokeThickness="2"/>
                                <Path Data="M12,6 L12,3" Stroke="#0D1117" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                <Path Data="M12,13 L15,10" Stroke="#0D1117" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            </Canvas>
                        </Viewbox>
                    </Border>
                    <TextBlock Grid.Column="1" Text="FASTEST LAP" FontSize="10.5" FontWeight="Bold" Foreground="#AFA9EC" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="{Binding FastestLapDriver}" FontSize="12" Foreground="#E6EDF3" VerticalAlignment="Center" Margin="10,0,8,0" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="3" Text="{Binding FastestLapTimeText}" FontSize="12.5" FontFamily="Consolas" FontWeight="Bold" Foreground="#AFA9EC" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <TextBlock Text="POSITION" FontSize="11" Foreground="#6B7684" Margin="0,0,0,10"/>

            <Grid Margin="4,0,4,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="58"/>
                    <!-- Real spacer columns (not alignment slack) so the Int-Gap and
                         Gap-Tyre gaps are identical and don't depend on how wide that
                         row's particular text happens to be. -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="20"/>
                    <!-- Same real-spacer treatment as Int-Gap-Tyre, then the pending-
                         penalty badge in what used to be the reserved column. -->
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="20"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="2" Text="Driver" FontSize="10.5" Foreground="#4A5460" Margin="8,0,0,0"/>
                <TextBlock Grid.Column="3" Text="Int" FontSize="10.5" Foreground="#4A5460" HorizontalAlignment="Right"/>
                <TextBlock Grid.Column="5" Text="Gap" FontSize="10.5" Foreground="#4A5460" HorizontalAlignment="Right"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding RaceStandings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Player's own row needs to be findable in under a second among 22
                             tightly-packed rows mid-race, not just subtly tinted - a left
                             accent stripe (same blue as the app's own accent buttons, not
                             otherwise used as a timing/status colour in this widget) plus a
                             brighter background and bold name give it a much stronger signal
                             than a background tint alone. -->
                        <Border Padding="7,5,4,5" CornerRadius="4" Margin="0,1" BorderThickness="3,0,0,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                            <Setter Property="Background" Value="#1B2A42"/>
                                            <Setter Property="BorderBrush" Value="#1F6FEB"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="58"/>
                                    <!-- Real spacer columns - see header row comment. -->
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="58"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="20"/>
                                    <!-- Spacer + penalty badge - see header row comment. -->
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="20"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="{Binding Position}" FontSize="13" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#E6EDF3"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOut}" Value="True">
                                                    <Setter Property="Foreground" Value="#4A5460"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <Border Grid.Column="1" Width="8" Height="8" CornerRadius="2" VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{Binding LiveryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOut}" Value="True">
                                                    <Setter Property="Background" Value="#4A5460"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                </Border>

                                <StackPanel Grid.Column="2" Margin="8,0,4,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding DriverName}" FontSize="13" TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPlayer}" Value="True">
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsOut}" Value="True">
                                                        <Setter Property="Foreground" Value="#4A5460"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding TeamName}" FontSize="9.5" TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#6B7684"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOut}" Value="True">
                                                        <Setter Property="Foreground" Value="#3A424C"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <!-- 2 decimals (not the app-wide 3, see TelemetryState.FormatDelta
                                     call site) frees up room here to run these up in size -
                                     still plenty precise for a gap glanced at mid-race. The
                                     interval-trend caret sits INSIDE the fixed 58px column, left
                                     of the right-aligned number, so the numbers stay aligned and
                                     no extra width is needed. Blank/neutral for everyone but the
                                     player - IntervalBrush is NeutralText except on the player's
                                     trending gap (green closing / red opening). -->
                                <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding IntervalCaret}" FontSize="9" Foreground="{Binding IntervalBrush}" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                    <TextBlock Text="{Binding IntervalText}" FontSize="13" FontFamily="Consolas" Foreground="{Binding IntervalBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="5" Text="{Binding GapText}" FontSize="12.5" FontFamily="Consolas" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#9BA7B4"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOut}" Value="True">
                                                    <Setter Property="Foreground" Value="#4A5460"/>
                                                </DataTrigger>
                                                <!-- "PIT" stands out in the same blue used for pit
                                                     times in Lap History - a car being serviced is a
                                                     notable, actionable state, not a dimmed/gone one. -->
                                                <DataTrigger Binding="{Binding IsPitting}" Value="True">
                                                    <Setter Property="Foreground" Value="#79C0FF"/>
                                                    <Setter Property="FontWeight" Value="Bold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Column="7" Text="{Binding TyreLetter}" FontSize="13" FontWeight="Bold" Foreground="{Binding TyreBrush}" FontFamily="Consolas" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                                <!-- Real F1 broadcast convention: a red "!" badge for a
                                     driver with a penalty they haven't served yet. Shares
                                     this column with the fastest-lap badge below - the two
                                     are mutually exclusive at the source (see
                                     TelemetryState.RefreshRaceStandings), so only one of
                                     these two Borders is ever visible for a given row. -->
                                <Border Grid.Column="9" Width="18" Height="18" CornerRadius="4" Background="#E12E2E" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding IsPenaltyPending, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="!" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                                </Border>

                                <!-- Purple stopwatch badge for whoever currently holds the
                                     session's fastest lap - reuses the existing purple =
                                     "fastest of the session" convention (Lap Timing colours). -->
                                <Border Grid.Column="9" Width="18" Height="18" CornerRadius="9" Background="#AFA9EC" HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding IsFastestLap, Converter={StaticResource BoolToVis}}">
                                    <Viewbox Width="12" Height="12">
                                        <Canvas Width="24" Height="24">
                                            <Ellipse Canvas.Left="5" Canvas.Top="6" Width="14" Height="14" Stroke="#0D1117" StrokeThickness="2"/>
                                            <Path Data="M12,6 L12,3" Stroke="#0D1117" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Path Data="M12,13 L15,10" Stroke="#0D1117" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
